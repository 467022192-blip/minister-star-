  "palaceDescriptorCatalog": {
    "命宫": { "label": "自我定盘", "summary": "先回到自我定位、表达方式与人格底色" },
    "兄弟宫": { "label": "协同结构", "summary": "先看同频合作、同伴反馈与关系排序" },
    "夫妻宫": { "label": "亲密镜像", "summary": "先通过亲密关系与承诺接口理解自己" },
    "子女宫": { "label": "创造输出", "summary": "先看表达欲、作品感与投放后的反馈" },
    "财帛宫": { "label": "资源调度", "summary": "先关注资源分配、价值回收与现实安全感" },
    "疾厄宫": { "label": "内耗修正", "summary": "先从身体感受、压力阈值与修复能力切入" },
    "迁移宫": { "label": "外部场域", "summary": "先通过环境变化、他人目光与位置转换来确认方向" },
    "仆役宫": { "label": "协作网络", "summary": "先从团队接口、合作节奏与支持系统判断机会" },
    "官禄宫": { "label": "目标推进", "summary": "先围绕目标、职责与职业进阶去组织行动" },
    "田宅宫": { "label": "稳定基底", "summary": "先关心边界、空间归属与长期安置" },
    "福德宫": { "label": "内在蓄能", "summary": "先回到情绪储备、精神安稳与内在秩序" },
    "父母宫": { "label": "规则承接", "summary": "先参考标准、权威与既有框架来安排节奏" }
  },
  "transformationDescriptorCatalog": {
    "化禄": { "label": "资源流入", "summary": "更容易通过关系、机会与可承接的接口靠近你" },
    "化科": { "label": "理解沉淀", "summary": "更适合先建立认知、方法和可解释性，再放大结果" },
    "化权": { "label": "掌控推进", "summary": "更需要明确权责、节奏和目标，事情才会真正往前走" }
  },
